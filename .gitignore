# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# sqlite database
/db/*.db

# ── Project-specific content (excluded to keep the repo generic) ──────────────

# Requirement docs (markdown files per story)
/src/requirements/

# Seed SQL files (contain story titles, test case summaries, project data)
/db/seed-*.sql
/db/schema-draft.md

# Per-story TypeScript data files (flows, testcases, scenario maps, conflicts)
/src/data/pp*/
/src/data/org-auth/
/src/data/user-*/
